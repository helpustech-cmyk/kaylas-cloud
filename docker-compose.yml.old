services:
  kaylas-cloud:
    build: .
    container_name: kaylas-cloud
    restart: unless-stopped
    expose:
      - 80
    networks:
      - traefik-public
    labels:
      - traefik.enable=true
      - traefik.http.routers.kaylas-cloud.rule=Host(`kaylas.cloud`)
      - traefik.http.routers.kaylas-cloud.entrypoints=websecure
      - traefik.http.routers.kaylas-cloud.tls.certresolver=letsencrypt
      - traefik.http.routers.kaylas-cloud.tls.domains[0].main=kaylas.cloud
      - traefik.http.services.kaylas-cloud.loadbalancer.server.port=80

networks:
  traefik-public:
    external: true
